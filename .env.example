# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Controls pilot behaviour: hides the account/payment buttons in the header
# (shows a "Private pilot" badge instead) and asks search engines not to
# index the site. Leave unset or "true" during the CIPD pilot. Set to
# "false" once accounts, payment and public advertising are ready to go live.
NEXT_PUBLIC_PILOT_MODE=true

# Free registration required: https://core.ac.uk/services/api
CORE_API_KEY=

# Crossref politely asks for a contact email on every request. No key needed.
CROSSREF_CONTACT_EMAIL=christophermccreanor@gmail.com

# Required as of February 2026: OpenAlex retired its free mailto-only "polite
# pool". Without this key, evidence search shares a $0.10/day budget across
# every visitor, which will not hold up under real traffic. Free account,
# 30 seconds: sign up at openalex.org, then copy the key from
# openalex.org/settings/api. Gives a $1/day free budget.
OPENALEX_API_KEY=

# Optional: raises the Google Books ISBN-lookup quota above the small
# unauthenticated allowance. Get one from console.cloud.google.com (enable
# the "Books API" on a project, then create an API key under Credentials).
GOOGLE_BOOKS_API_KEY=

# From the Paystack dashboard (Settings > API Keys & Webhooks). Test key first, live key only once ready to charge real students.
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Optional, for search-result caching and rate limiting once traffic justifies it.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
